generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  BANK_TRANSFER
  STRIPE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum AddressType {
  BILLING
  SHIPPING
  BOTH
}

enum ProductStatus {
  SHOP
  ORDERED
  SOLD
}

enum Category {
  NECKLACES
  RINGS
  EARRINGS
  BRACELETS
  CHAINS
}

model Collection {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id             String        @id
  slug           String?       @unique
  name           String
  priceInGrosz   Int           // Price in PLN grosz (1 PLN = 100 grosz)
  priceInCents   Int           // Price in EUR cents (1 EUR = 100 cents)
  imagePaths     String[]
  description    String
  materials      String?
  productStatus  ProductStatus @default(SHOP)
  isAvailable    Boolean       @default(true)
  isFeatured     Boolean       @default(false)
  category       Category      @default(RINGS)
  collectionId   String?
  collection     Collection?   @relation(fields: [collectionId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  imagePublicIds String[]
  orderItems     OrderItem[]
}

model User {
  id          String      @id @default(uuid())
  email       String      @unique
  password    String?
  firstName   String?
  lastName    String?
  phoneNumber String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orders      Order[]
  addresses   Address[]
  payments    Payment[]
}

model Address {
  id                String      @id @default(uuid())
  userId            String
  street            String
  city              String
  postalCode        String
  country           String
  isDefault         Boolean     @default(false)
  addressType       AddressType @default(BOTH)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingOrders     Order[]     @relation("BillingAddress")
  shippingOrders    Order[]     @relation("ShippingAddress")
}

model Order {
  id                  String       @id @default(uuid())
  userId              String
  status              OrderStatus  @default(PENDING)
  paymentMethod       PaymentMethod
  pricePaid    Int         // Total price including VAT
  subtotal     Int         // Total price including VAT before shipping
  shippingCost Int
  billingAddressId    String
  shippingAddressId   String
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingAddress      Address      @relation("BillingAddress", fields: [billingAddressId], references: [id])
  shippingAddress     Address      @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  orderItems          OrderItem[]
  payments            Payment[]
}

model OrderItem {
  id                 String   @id @default(uuid())
  orderId            String
  productId          String
  priceInGrosz       Int      // Price per item in PLN grosz
  currency           String   @default("PLN") // Currency used for this order item
  createdAt          DateTime @default(now())
  order              Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product            Product  @relation(fields: [productId], references: [id])
}

model Payment {
  id                String        @id @default(uuid())
  orderId           String
  userId            String
  amount            Int
  currency          String        @default("PLN")
  status            PaymentStatus @default(PENDING)
  paymentMethodType PaymentMethod
  transactionId     String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HeroContent {
  id             String   @id @default(uuid())
  description    String
  imagePaths     String[]
  imagePublicIds String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum GalleryLayout {
  THREE_COL
  FIVE_COL
}

model PhotoArtist {
  id        String         @id @default(uuid())
  name      String         @unique
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  images    GalleryImage[]
}

model GalleryRow {
  id        String         @id @default(uuid())
  layout    GalleryLayout
  order     Int
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  images    GalleryImage[]
}

model GalleryImage {
  id        String      @id @default(uuid())
  imagePath String
  publicId  String
  order     Int
  artistId  String
  rowId     String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  artist    PhotoArtist @relation(fields: [artistId], references: [id])
  row       GalleryRow  @relation(fields: [rowId], references: [id], onDelete: Cascade)
}

model MarqueeContent {
  id          String   @id @default(uuid())
  description String
  href        String?
  textHref    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NavCarouselContent {
  id        String   @id @default(uuid())
  texts     String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
